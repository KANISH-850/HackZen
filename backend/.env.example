# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/unsafe_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Camera / Stream settings
# Comma separated for multiple cameras, '0' for local webcam
RTSP_URLS=0
FPS=15

# ML Models Paths
DETECTOR_MODEL_PATH=weights/detector.onnx
POSE_ESTIMATOR_MODEL_PATH=weights/pose_estimator.onnx
TRACKER_MODEL_PATH=weights/tracker.onnx
ANOMALY_MODEL_PATH=weights/anomaly_model.pkl
RISK_PREDICTOR_MODEL_PATH=weights/risk_predictor.onnx

# Alerts thresholds
RISK_THRESHOLD_CAUTION=0.5
RISK_THRESHOLD_CRITICAL=0.8
