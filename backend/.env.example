# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/unsafe_db

# Redis
REDIS_URL=redis://localhost:6379/0

# Camera / Stream settings
# Comma separated for multiple cameras, '0' for local webcam
RTSP_URLS=0
FPS=15

# YOLO .pt weights are auto-discovered from MODELS_DIR by filename. These settings
# name the filename stem (no extension) of the weight file for each role — a role
# with no matching file stays unloaded rather than being faked.
MODELS_DIR=models
PERSON_MODEL_KEY=person
PPE_MODEL_KEY=best
POSE_MODEL_KEY=pose

# Optional non-YOLO models (loaded only if the file exists)
ANOMALY_MODEL_PATH=weights/anomaly_model.pkl
RISK_PREDICTOR_MODEL_PATH=weights/risk_predictor.onnx

# Alerts thresholds
RISK_THRESHOLD_CAUTION=0.5
RISK_THRESHOLD_CRITICAL=0.8
